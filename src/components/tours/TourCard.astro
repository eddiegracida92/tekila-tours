---
import { Picture } from 'astro:assets';
import type { Tour } from '@/data/tours';
import { useTranslations, type Lang } from '@/i18n/ui';

interface Props {
  tour: Tour;
  lang: Lang;
}

const { tour, lang } = Astro.props;
const t = useTranslations(lang);
const content = tour[lang];

// Ancho de tarjeta: 100vw en móvil, ~50vw en tablet, ~360px (col) en desktop.
const cardSizes = '(max-width: 700px) 100vw, (max-width: 1100px) 50vw, 360px';
---

<article class="tour-card">
  <Picture
    src={tour.image}
    formats={['avif', 'webp']}
    alt={content.name}
    class="tour-card-img"
    widths={[360, 480, 720]}
    sizes={cardSizes}
    loading="lazy"
  />

  <div class="tour-card-base">
    <p class="tour-tag">{content.tag}</p>
    <h3 class="tour-name">{content.name}</h3>
  </div>

  <div class="tour-card-hover">
    <p class="tour-tag">{content.tag}</p>
    <h3 class="tour-name">{content.name}</h3>
    <p class="tour-desc">{content.desc}</p>
    <a href="#reserva" class="btn-book" data-book-tour={tour.id}>
      {t('tours.book_this')}
    </a>
  </div>
</article>
