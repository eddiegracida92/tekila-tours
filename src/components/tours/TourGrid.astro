---
import type { CatalogTour } from '@/lib/catalog';
import type { Lang } from '@/i18n/ui';
import TourCard from './TourCard.astro';

interface Props {
  tours: CatalogTour[];
  lang: Lang;
}

const { tours, lang } = Astro.props;
---

<div class="tours-grid">
  {tours.map((tour) => <TourCard tour={tour} lang={lang} />)}
</div>
