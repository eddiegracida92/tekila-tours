---
/**
 * Formulario de alta/edición de vendedor (Step 9.5). Server-side puro.
 * Lo usa solo el owner. El email aparece únicamente en el alta (no se cambia
 * después). La contraseña no se edita aquí: en el alta se genera temporal.
 */
import { COMISION_TIPOS, PERMISOS } from '@/lib/admin/vendedores';

interface Props {
  vendedor?: Record<string, any>;
  action: string;
  submitLabel: string;
  cancelHref: string;
  esNuevo: boolean;
  errors?: string[];
}

const { vendedor = {}, action, submitLabel, cancelHref, esNuevo, errors = [] } = Astro.props;
const val = (k: string, d: string = '') => (vendedor[k] ?? d) as string;
const permisos = (vendedor.permisos ?? {}) as Record<string, unknown>;
const permMarcado = (k: string) => permisos[k] === true;
---

<form class="vendedor-form" method="POST" action={action}>
  {
    errors.length > 0 && (
      <ul class="errors" role="alert">
        {errors.map((e) => (
          <li>{e}</li>
        ))}
      </ul>
    )
  }

  <div class="grid">
    {
      esNuevo && (
        <label>
          <span>Correo del vendedor</span>
          <input type="email" name="email" value={val('email')} required placeholder="vendedor@correo.com" />
        </label>
      )
    }
    <label>
      <span>Nombre</span>
      <input name="nombre" value={val('nombre')} required />
    </label>
  </div>

  <fieldset>
    <legend>Comisión (opcional)</legend>
    <p class="hint">Se calcula sobre el total de la venta (nunca sobre el margen/PR) y se congela por reserva al vender.</p>
    <div class="grid">
      <label>
        <span>Tipo</span>
        <select name="comision_tipo">
          <option value="" selected={!vendedor.comision_tipo}>Sin comisión</option>
          {
            COMISION_TIPOS.map((tp) => (
              <option value={tp} selected={vendedor.comision_tipo === tp}>
                {tp === 'porcentaje' ? 'Porcentaje (%)' : 'Monto fijo'}
              </option>
            ))
          }
        </select>
      </label>
      <label>
        <span>Valor</span>
        <input type="number" step="0.01" min="0" name="comision_valor" value={val('comision_valor')} placeholder="Ej. 10" />
      </label>
    </div>
  </fieldset>

  <fieldset>
    <legend>Permisos</legend>
    {
      PERMISOS.map((p) => (
        <label class="switch">
          <input type="checkbox" name={p.key} checked={permMarcado(p.key)} />
          <span>
            {p.label}
            <em>{p.hint}</em>
          </span>
        </label>
      ))
    }
  </fieldset>

  <div class="actions">
    <a href={cancelHref} class="cancel">Cancelar</a>
    <button type="submit">{submitLabel}</button>
  </div>
</form>

<style>
  .vendedor-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5, 1.25rem);
    max-width: 640px;
  }
  .errors {
    margin: 0;
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-8);
    background: var(--color-destructive);
    color: var(--color-white);
    border-radius: var(--radius);
    font-size: var(--fs-sm);
  }
  fieldset {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  legend {
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
    color: var(--color-navy);
    padding: 0 var(--space-2);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-4);
  }
  label {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
  }
  input,
  select {
    font: inherit;
    font-weight: var(--fw-regular);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-sand);
  }
  input:focus-visible,
  select:focus-visible {
    outline: 2px solid var(--color-teal);
    outline-offset: 1px;
  }
  .hint {
    margin: 0;
    font-size: var(--fs-xs);
    color: var(--color-muted);
  }
  .switch {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-2);
    font-weight: var(--fw-semibold);
  }
  .switch input {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 2px;
    accent-color: var(--color-teal);
    flex-shrink: 0;
  }
  .switch span {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .switch em {
    font-style: normal;
    font-weight: var(--fw-regular);
    font-size: var(--fs-xs);
    color: var(--color-muted);
  }
  .actions {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-4);
  }
  .cancel {
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-muted);
    text-decoration: none;
  }
  .cancel:hover {
    color: var(--color-navy);
  }
  button {
    font: inherit;
    font-weight: var(--fw-bold);
    padding: var(--space-3) var(--space-8);
    color: var(--color-white);
    background: var(--color-cta);
    border: none;
    border-radius: var(--radius);
    cursor: pointer;
  }
  button:hover {
    background: var(--color-coral-dim);
  }
</style>
