---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { createServerSupabase } from '@/lib/auth';

const supabase = createServerSupabase(Astro.request, Astro.cookies);

let aviso: string | null = null;

// Flash tras guardar/crear (redirect desde el form de edición/alta).
const ok = Astro.url.searchParams.get('ok');
if (ok === 'guardado') aviso = 'Cambios guardados.';
else if (ok === 'creado') aviso = 'Tour creado.';

// Toggle activo/inactivo desde el listado (POST a esta misma ruta).
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const id = String(form.get('id') ?? '');
  const activar = form.get('activar') === '1';
  if (id) {
    const { error } = await supabase.from('tours').update({ activo: activar }).eq('id', id);
    aviso = error ? 'No se pudo cambiar el estado.' : activar ? 'Tour activado.' : 'Tour desactivado.';
  }
}

const { data: tours, error } = await supabase
  .from('tours')
  .select('id, slug, nombre_es, categoria_es, activo, orden')
  .order('orden', { ascending: true })
  .order('nombre_es', { ascending: true });
---

<AdminLayout title="Tours y tarifas" active="tours">
  <div class="head">
    <p class="count">{tours?.length ?? 0} tours en el catálogo</p>
    <a class="new" href="/admin/tours/nuevo">+ Nuevo tour</a>
  </div>

  {aviso && <p class="aviso">{aviso}</p>}
  {error && <p class="aviso err">No se pudieron cargar los tours: {error.message}</p>}

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Nombre</th>
          <th>Categoría</th>
          <th>Estado</th>
          <th class="right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        {
          (tours ?? []).map((t) => (
            <tr class:list={[{ off: !t.activo }]}>
              <td class="muted">{t.orden}</td>
              <td>
                <a class="name" href={`/admin/tours/${t.id}`}>
                  {t.nombre_es}
                </a>
                <span class="slug">/{t.slug}</span>
              </td>
              <td>{t.categoria_es ?? '—'}</td>
              <td>
                <span class:list={['badge', t.activo ? 'on' : 'no']}>
                  {t.activo ? 'Activo' : 'Inactivo'}
                </span>
              </td>
              <td class="right">
                <a class="action" href={`/admin/tours/${t.id}`}>
                  Editar
                </a>
                <form method="POST" class="inline">
                  <input type="hidden" name="id" value={t.id} />
                  <input type="hidden" name="activar" value={t.activo ? '0' : '1'} />
                  <button type="submit" class="linkbtn">
                    {t.activo ? 'Desactivar' : 'Activar'}
                  </button>
                </form>
              </td>
            </tr>
          ))
        }
        {
          (tours ?? []).length === 0 && (
            <tr>
              <td colspan="5" class="empty">
                Aún no hay tours. Crea el primero con “+ Nuevo tour”.
              </td>
            </tr>
          )
        }
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }
  .count {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--fs-sm);
  }
  .new {
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    background: var(--color-cta);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius);
    text-decoration: none;
  }
  .new:hover {
    background: var(--color-coral-dim);
  }
  .aviso {
    margin: 0 0 var(--space-4);
    padding: var(--space-3);
    background: var(--color-surface);
    border-left: 3px solid var(--color-teal);
    border-radius: var(--radius);
    font-size: var(--fs-sm);
  }
  .aviso.err {
    border-left-color: var(--color-destructive);
  }
  .table-wrap {
    overflow-x: auto;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-sm);
  }
  th,
  td {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }
  th {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    background: var(--color-surface);
  }
  tbody tr:last-child td {
    border-bottom: none;
  }
  tr.off {
    opacity: 0.55;
  }
  .right {
    text-align: right;
  }
  .muted {
    color: var(--color-muted);
  }
  .name {
    font-weight: var(--fw-bold);
    color: var(--color-navy);
    text-decoration: none;
  }
  .name:hover {
    text-decoration: underline;
  }
  .slug {
    display: block;
    color: var(--color-muted);
    font-size: var(--fs-xs);
  }
  .badge {
    display: inline-block;
    padding: 2px var(--space-2);
    border-radius: var(--radius-full);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
  }
  .badge.on {
    color: var(--color-success);
    background: rgb(28 191 192 / 0.14);
  }
  .badge.no {
    color: var(--color-muted);
    background: var(--color-surface);
  }
  .action {
    color: var(--color-teal-dim);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    margin-right: var(--space-3);
  }
  .action:hover {
    text-decoration: underline;
  }
  .inline {
    display: inline;
  }
  .linkbtn {
    font: inherit;
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .linkbtn:hover {
    color: var(--color-navy);
    text-decoration: underline;
  }
  .empty {
    text-align: center;
    color: var(--color-muted);
    padding: var(--space-8);
  }
</style>
