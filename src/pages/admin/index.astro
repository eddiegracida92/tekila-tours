---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';

// El middleware ya garantizó que hay un admin autenticado en `locals.admin`.
const admin = Astro.locals.admin!;
const saludo = admin.nombre ?? admin.email;
---

<AdminLayout title="Dashboard" active="dashboard">
  <section class="welcome">
    <h2>Hola, {saludo} 👋</h2>
    <p>
      Bienvenido al panel de administración. Aquí vivirán los tours, tarifas,
      reservas, vendedores y el dashboard de ventas.
    </p>
  </section>

  <div class="grid">
    <a class="tile link" href="/admin/tours">
      <h3>Tours y tarifas</h3>
      <p>Alta y edición del catálogo. La matriz de precios llega en 9.3.</p>
      <span class="go">Gestionar →</span>
    </a>
    <article class="tile">
      <h3>Reservas</h3>
      <p>Ver reservas pagadas, estados y detalle de cada venta.</p>
      <span class="soon">Step 9.3</span>
    </article>
    <article class="tile">
      <h3>Vendedores</h3>
      <p>Crear cuentas, fijar comisión y permisos (incluido ver PR).</p>
      <span class="soon">Step 9.3</span>
    </article>
    <article class="tile">
      <h3>Ventas y margen</h3>
      <p>Ingresos, margen (PP−PR) y comisiones por vendedor.</p>
      <span class="soon">Step 9.4</span>
    </article>
  </div>
</AdminLayout>

<style>
  .welcome h2 {
    font-family: var(--font-display);
    font-size: var(--fs-h2);
    margin: 0 0 var(--space-2);
    color: var(--color-navy);
  }
  .welcome p {
    margin: 0 0 var(--space-8);
    max-width: 60ch;
    color: var(--color-muted);
    line-height: var(--lh-body);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .tile {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .tile h3 {
    font-family: var(--font-display);
    font-size: var(--fs-h3);
    margin: 0;
    color: var(--color-navy);
  }
  .tile p {
    margin: 0;
    flex: 1;
    font-size: var(--fs-sm);
    color: var(--color-muted);
    line-height: var(--lh-body);
  }
  .soon {
    align-self: flex-start;
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    color: var(--color-gold-dim);
    background: var(--color-surface);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-full);
  }
  .tile.link {
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .tile.link:hover {
    border-color: var(--color-teal);
  }
  .go {
    align-self: flex-start;
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    color: var(--color-teal-dim);
  }
</style>
