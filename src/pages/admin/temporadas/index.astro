---
export const prerender = false;

import AdminLayout from '@/layouts/AdminLayout.astro';
import { createServerSupabase, esOwner } from '@/lib/auth';

const admin = Astro.locals.admin!;
const owner = esOwner(admin);
const supabase = createServerSupabase(Astro.request, Astro.cookies);

let aviso: string | null = null;

// Acción desde el listado: eliminar. SOLO owner.
if (Astro.request.method === 'POST') {
  if (!owner) {
    aviso = 'Solo el owner puede modificar temporadas.';
  } else {
    const form = await Astro.request.formData();
    const accion = form.get('accion');
    const tid = String(form.get('tid') ?? '');
    if (tid && accion === 'eliminar') {
      const { error } = await supabase.from('temporadas').delete().eq('id', tid);
      aviso = error ? 'No se pudo eliminar.' : 'Temporada eliminada.';
    }
  }
}

const { data: temporadas } = await supabase
  .from('temporadas')
  .select('*')
  .order('fecha_inicio', { ascending: true });

const fmt = (iso: string) =>
  new Date(`${iso}T00:00:00`).toLocaleDateString('es-MX', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
  });
---

<AdminLayout title="Temporadas" active="temporadas">
  <div class="head">
    <div>
      <p class="count">{temporadas?.length ?? 0} temporadas</p>
      <p class="desc">
        Rangos de fecha que definen precios de temporada baja/alta (Grupo Xcaret y
        similares). El motor de precios elige la tarifa según la fecha del tour.
      </p>
    </div>
    {owner && <a class="new" href="/admin/temporadas/nueva">+ Nueva temporada</a>}
  </div>

  {aviso && <p class="aviso">{aviso}</p>}
  {!owner && <p class="pr-note">Solo el owner puede crear o editar temporadas. Aquí puedes consultarlas.</p>}

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Tipo</th>
          <th>Etiqueta</th>
          <th>Inicio</th>
          <th>Fin</th>
          {owner && <th class="right">Acciones</th>}
        </tr>
      </thead>
      <tbody>
        {(temporadas ?? []).map((t) => (
          <tr>
            <td>
              <span class:list={['badge', t.tipo]}>{t.tipo === 'alta' ? 'Alta' : 'Baja'}</span>
            </td>
            <td>{t.etiqueta ?? '—'}</td>
            <td>{fmt(t.fecha_inicio)}</td>
            <td>{fmt(t.fecha_fin)}</td>
            {owner && (
              <td class="right">
                <a class="action" href={`/admin/temporadas/${t.id}`}>
                  Editar
                </a>
                <form method="POST" class="inline" onsubmit="return confirm('¿Eliminar esta temporada? No se puede deshacer.')">
                  <input type="hidden" name="accion" value="eliminar" />
                  <input type="hidden" name="tid" value={t.id} />
                  <button type="submit" class="linkbtn danger">
                    Eliminar
                  </button>
                </form>
              </td>
            )}
          </tr>
        ))}
        {(temporadas ?? []).length === 0 && (
          <tr>
            <td colspan={owner ? 5 : 4} class="empty">
              Aún no hay temporadas. Los tours sin temporada usan la tarifa "única".
            </td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  .head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
  }
  .count {
    margin: 0 0 var(--space-1);
    color: var(--color-navy);
    font-weight: var(--fw-bold);
  }
  .desc {
    margin: 0;
    color: var(--color-muted);
    font-size: var(--fs-sm);
    max-width: 60ch;
  }
  .new {
    flex-shrink: 0;
    font-size: var(--fs-sm);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    background: var(--color-cta);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius);
    text-decoration: none;
  }
  .new:hover {
    background: var(--color-coral-dim);
  }
  .aviso {
    margin: 0 0 var(--space-4);
    padding: var(--space-3);
    background: var(--color-surface);
    border-left: 3px solid var(--color-teal);
    border-radius: var(--radius);
    font-size: var(--fs-sm);
  }
  .pr-note {
    margin: 0 0 var(--space-4);
    padding: var(--space-3);
    background: var(--color-surface);
    border-radius: var(--radius);
    font-size: var(--fs-sm);
    color: var(--color-muted);
  }
  .table-wrap {
    overflow-x: auto;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-sm);
  }
  th,
  td {
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }
  th {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    color: var(--color-navy);
    background: var(--color-surface);
  }
  tbody tr:last-child td {
    border-bottom: none;
  }
  .right {
    text-align: right;
  }
  .badge {
    display: inline-block;
    padding: 2px var(--space-2);
    border-radius: var(--radius-full);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
  }
  .badge.alta {
    color: var(--color-coral);
    background: rgb(224 90 43 / 0.14);
  }
  .badge.baja {
    color: var(--color-teal-dim);
    background: rgb(28 191 192 / 0.14);
  }
  .action {
    color: var(--color-teal-dim);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    margin-right: var(--space-3);
  }
  .action:hover {
    text-decoration: underline;
  }
  .inline {
    display: inline;
    margin-left: var(--space-3);
  }
  .linkbtn {
    font: inherit;
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .linkbtn:hover {
    color: var(--color-navy);
    text-decoration: underline;
  }
  .linkbtn.danger:hover {
    color: var(--color-destructive);
  }
  .empty {
    text-align: center;
    color: var(--color-muted);
    padding: var(--space-8);
    white-space: normal;
  }
</style>
