# =====================================================================
# Tekila Tours — Variables de entorno (plantilla)
# Copiar a .env y llenar valores reales:   cp .env.example .env
# NUNCA prefijar un secreto con PUBLIC_ (eso lo expone al navegador).
# Los secretos solo se usan en el servidor (src/pages/api/*).
# =====================================================================

# ---- Supabase (Step 1 / Step 4) ----
# Supabase → Project Settings → API Keys
# Formato nuevo: la pública empieza con `sb_publishable_`, la secreta con `sb_secret_`.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SECRETO — solo servidor. Supabase → Project Settings → API Keys → secret key
SUPABASE_SECRET_KEY=

# ---- Sitio ----
# URL canónica (local: http://localhost:4321 · prod: https://tudominio.com)
PUBLIC_SITE_URL=http://localhost:4321

# ---- Stripe (Step 8, MVP) ----
# Usamos Stripe Checkout (página de pago alojada por Stripe) → SOLO se necesita
# la Secret key. La Publishable key (pk_...) no se usa (el form de tarjeta vive
# en Stripe, no en el sitio). Modo test: la key empieza con `sk_test_`.
# Stripe → Developers → API keys.
STRIPE_SECRET_KEY=
# Se llena en el Step 8.2 al crear el endpoint del webhook (empieza con `whsec_`).
STRIPE_WEBHOOK_SECRET=

# ---- Emails: Resend (Step 8.3b) ----
# Resend → API Keys. La key empieza con `re_`.
RESEND_API_KEY=
# Remitente. SIN dominio verificado usa el de prueba de Resend (entrega SOLO a
# la dirección de tu cuenta Resend). En producción, verifica tu dominio y pon:
#   EMAIL_FROM=Tekila Tours <reservas@tudominio.com>
EMAIL_FROM=Tekila Tours <onboarding@resend.dev>

# ---- Pagos fase 2 (Step 13) ----
MERCADOPAGO_ACCESS_TOKEN=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
