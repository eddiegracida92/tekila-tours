# =====================================================================
# Tekila Tours — Variables de entorno (plantilla)
# Copiar a .env y llenar valores reales:   cp .env.example .env
# NUNCA prefijar un secreto con PUBLIC_ (eso lo expone al navegador).
# Los secretos solo se usan en el servidor (src/pages/api/*).
# =====================================================================

# ---- Supabase (Step 1 / Step 4) ----
# Supabase → Project Settings → API Keys
# Formato nuevo: la pública empieza con `sb_publishable_`, la secreta con `sb_secret_`.
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SECRETO — solo servidor. Supabase → Project Settings → API Keys → secret key
SUPABASE_SECRET_KEY=

# ---- Sitio ----
# URL canónica (local: http://localhost:4321 · prod: https://tudominio.com)
PUBLIC_SITE_URL=http://localhost:4321

# ---- Stripe (Step 8, MVP) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Emails: Resend (Step 8) ----
RESEND_API_KEY=

# ---- Pagos fase 2 (Step 13) ----
MERCADOPAGO_ACCESS_TOKEN=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
